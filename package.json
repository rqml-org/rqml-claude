{
  "name": "rqml-claude",
  "private": true,
  "version": "0.1.0",
  "description": "Claude Code plugin: RQML spec-first enforcement (tests only; the plugin itself has no build step)",
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "test": "node --test \"test/**/*.test.mjs\""
  },
  "rqmlToolchain": {
    "compatible": "@rqml/cli >=0.1.1 <0.3.0",
    "contract": "exit codes 0/1/2/64; status/check --json report shapes"
  }
}
