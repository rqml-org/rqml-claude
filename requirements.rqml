  <!-- GOVERNANCE                                                    -->
  <!-- ============================================================= -->
  <governance>
    <issue id="ISS-IMPL-ZERO" status="review" owner="STK-MAINTAINER">
      <statement>
        Resolved in practice: the spec preceded the plugin (drafted and
        approved 2026-06-10 with implementation coverage at zero), and every
        implements/verifiedBy edge was then recorded with rqml link as the
        corresponding artifact landed the same day. The drift baseline
        (.rqml/baseline.json) is committed so the gate detects changed
        implementations from here on.
      </statement>
      <notes>Dogfood baseline, mirroring ISS-IMPL-TRACE in RQML-SELF-001.</notes>
    </issue>
    <issue id="ISS-OTHER-AGENTS" status="review" owner="STK-MAINTAINER">
      <statement>
        This repository targets Claude Code only. Equivalent adapters for
        other agent hosts should reuse the same shape — anchor, validate,
        gate — but live in their own repositories with their own specs.
      </statement>
    </issue>
    <issue id="ISS-HOOK-EVENTS" status="review" owner="STK-MAINTAINER">
      <statement>
        Open question: whether a per-prompt hook (UserPromptSubmit) adds value
        beyond session-start anchoring, or only noise and latency. Deferred
        until the three core hooks have field experience.
      </statement>
    </issue>
    <approval id="APR-MAINTAINER" role="RQML Maintainer" status="draft">
      <description>Maintainer sign-off on the rqml-claude specification.</description>
    </approval>
  </governance>

</rqml>
