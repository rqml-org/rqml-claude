<?xml version="1.0" encoding="UTF-8"?>
<!--
  requirements.rqml — rqml-claude specified in RQML (more dogfooding).

  This document specifies the Claude Code plugin that turns the deterministic
  primitives of the RQML toolchain (rqml check / status / show / impact / link,
  the @rqml/mcp server) into an enforced spec-first development loop inside
  Claude Code. The upstream self-specification (RQML-SELF-001, governance issue
  ISS-PLUGIN-SCOPE) deliberately deferred this harness to a downstream
  integration repository; this is that repository.

  The spec led the code: every requirement below was written and approved
  before the plugin was built, and every implements/verifiedBy edge in the
  trace section was recorded with `rqml link` as the corresponding piece
  landed (see ISS-IMPL-ZERO for the history of that baseline).
-->
<rqml xmlns="https://rqml.org/schema/2.1.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="https://rqml.org/schema/2.1.0 https://rqml.org/schema/rqml-2.1.0.xsd"
      version="2.1.0" docId="RQML-CLAUDE-001" status="draft">

  <!-- ============================================================= -->
  <!-- META                                                          -->
  <!-- ============================================================= -->
  <meta>
    <title>rqml-claude — RQML spec-first enforcement for Claude Code</title>
    <system>rqml-claude</system>
    <summary>
      A Claude Code plugin that makes spec-first development enforced rather
      than voluntary. Deterministic hooks anchor every session on the project
      spec, validate spec edits as they happen, and gate session completion on
      the rqml check verdict; bundled slash commands and the @rqml/mcp server
      give the agent the full read/record loop (show, impact, link, skeleton).
      The plugin contains no requirements logic of its own: every verdict comes
      from the rqml CLI, so what blocks the agent locally is exactly what
      blocks CI.
    </summary>
    <authors>
      <author>
        <name>Garðar Guðgeirsson</name>
        <role>RQML Maintainer</role>
        <org>rqml.org</org>
        <contact>https://github.com/gudgeirsson</contact>
      </author>
    </authors>
    <dates>
      <created>2026-06-10</created>
      <updated>2026-06-13</updated>
    </dates>
    <conventions>
      <normativeKeywords>
        MUST, MUST NOT, SHALL, SHALL NOT, SHOULD, SHOULD NOT, and MAY are to be
        interpreted as described in RFC 2119 / RFC 8174, mapped to the RQML
        PriorityType vocabulary (must / should / may).
      </normativeKeywords>
      <idConventions>
        IDs follow the upstream conventions: REQ-&lt;NAME&gt; for requirements,
        GOAL-/QGOAL- for goals, ENT- for entities, SM-/ST-/TR- for behavior,
        TC- for tests, DEC- for decisions, RISK-/OBS- for risks and obstacles.
      </idConventions>
    </conventions>
  </meta>

  <!-- ============================================================= -->
  <!-- CATALOGS                                                      -->
  <!-- ============================================================= -->
  <catalogs>
    <actors>
      <actor id="ACT-AGENT" name="Claude Code Agent" type="system">
        <description>
          The coding agent working inside a project. It reads the spec, writes
          code, and is the subject of enforcement — the loop must hold even
          when the agent forgets the process exists.
        </description>
      </actor>
      <actor id="ACT-HOST" name="Claude Code Hook Runtime" type="system">
        <description>
          The Claude Code plugin host: it loads the plugin manifest, fires hook
          events (session start, tool use, stop), renders slash commands, and
          launches configured MCP servers.
        </description>
      </actor>
      <actor id="ACT-CLI" name="rqml CLI" type="system">
        <description>
          The deterministic verdict source (@rqml/cli). Every enforcement
          decision the plugin surfaces originates here, via documented exit
          codes and JSON output.
        </description>
      </actor>
      <actor id="ACT-DEV" name="Developer" type="human">
        <description>
          The human who installs the plugin, owns the spec, and approves
          requirements. Enforcement must inform the developer, never silently
          override them.
        </description>
      </actor>
    </actors>

    <stakeholders>
      <stakeholder id="STK-TEAMS" name="Adopting Teams">
        <concerns>
          Spec-first enforcement that materially improves agent output without
          adding friction to every turn — and that can be uninstalled without
          leaving residue.
        </concerns>
      </stakeholder>
      <stakeholder id="STK-MAINTAINER" name="RQML Maintainer" org="rqml.org">
        <concerns>
          A thin, faithful adapter over the toolchain: no duplicated logic that
          could drift from the engine, and a reference design reusable for
          other agent hosts.
        </concerns>
      </stakeholder>
    </stakeholders>

    <constraints>
      <constraint id="CON-PLUGIN-FORMAT" severity="blocking">
        <statement>
          The plugin MUST conform to the Claude Code plugin format: a
          .claude-plugin/plugin.json manifest, with hooks, commands, skills,
          and MCP configuration in their documented locations.
        </statement>
        <source>Claude Code plugin documentation.</source>
      </constraint>
      <constraint id="CON-DETERMINISTIC" severity="blocking">
        <statement>
          No language model SHALL participate in any enforcement verdict the
          plugin produces; verdicts come from the rqml CLI exit codes and JSON.
        </statement>
        <source>Upstream constraint CON-DETERMINISTIC-GATE (RQML-SELF-001).</source>
      </constraint>
      <constraint id="CON-OFFLINE" severity="high">
        <statement>
          Hooks SHALL work without network access once the toolchain is
          installed; nothing is fetched at hook time.
        </statement>
        <source>Hooks run on every session and stop event; latency and reliability budgets forbid network calls.</source>
      </constraint>
      <constraint id="CON-NODE" severity="high">
        <statement>
          The plugin MAY assume a Node.js runtime (18 or newer) is available on
          the developer's machine, since the toolchain it drives requires one.
        </statement>
      </constraint>
    </constraints>

    <decisions>
      <decision id="DEC-HOOKS-NOT-PROMPTS" status="approved">
        <context>
          Instructing an agent to follow a spec-first process works until the
          context window rotates or attention drifts; the upstream spec calls
          this failure mode out as obstacle OBS-VOLUNTARY.
        </context>
        <decision>
          Enforce the process with deterministic Claude Code hooks — context
          injection at session start, validation feedback on spec edits, and a
          blocking gate on stop — rather than relying on instructions, memory,
          or agent goodwill.
        </decision>
        <alternatives>
          AGENTS.md instructions alone (rejected: voluntary compliance is the
          documented failure mode); a subagent reviewer (rejected: puts a model
          in the verdict path).
        </alternatives>
        <consequences>
          The loop holds for the life of a session regardless of context
          length; hook latency becomes a first-class quality goal.
        </consequences>
      </decision>
      <decision id="DEC-THIN-ADAPTER" status="approved">
        <context>
          The toolchain already computes validation, coverage, drift, impact,
          and extraction deterministically, and CI runs the same CLI.
        </context>
        <decision>
          The plugin SHALL contain no requirements logic of its own. It is an
          adapter: hooks shell out to the rqml CLI, commands wrap CLI
          invocations, and agent tools come from the unmodified @rqml/mcp
          server.
        </decision>
        <alternatives>
          Reimplementing checks in hook scripts (rejected: two implementations
          drift apart and local verdicts diverge from CI).
        </alternatives>
        <consequences>
          Local blocking behavior is bit-identical to the CI gate; plugin code
          stays small enough to audit in minutes.
        </consequences>
      </decision>
      <decision id="DEC-CLI-FOR-HOOKS" status="approved">
        <context>
          The toolchain offers two surfaces: the CLI and the MCP server. Hooks
          run headless and must produce exit-code semantics; the agent's
          interactive loop benefits from structured tools.
        </context>
        <decision>
          Hooks SHALL invoke the rqml CLI; the agent's interactive loop
          (reading requirements, impact analysis, recording links) SHALL go
          through the bundled @rqml/mcp server.
        </decision>
        <consequences>
          Each surface is used where it is strongest; both are backed by one
          engine, so they cannot disagree.
        </consequences>
      </decision>
      <decision id="DEC-FAIL-OPEN" status="approved">
        <context>
          The plugin may be installed in environments where the rqml CLI is
          missing, broken, or the project has no spec at all.
        </context>
        <decision>
          When the toolchain is unavailable or the project is not
          RQML-governed, the plugin SHALL fail open: warn at most once, block
          nothing, and add no per-turn overhead.
        </decision>
        <alternatives>
          Fail closed (rejected: a missing binary would brick every session;
          adoption dies on the first false block).
        </alternatives>
        <consequences>
          Enforcement is only as strong as the environment is healthy; CI
          remains the backstop that always runs the real gate.
        </consequences>
      </decision>
      <decision id="DEC-MARKETPLACE" status="review">
        <context>
          Claude Code installs plugins from marketplaces — git repositories
          carrying a .claude-plugin/marketplace.json.
        </context>
        <decision>
          This repository SHALL double as its own single-plugin marketplace so
          installation is one command pointing at rqml-org/rqml-claude.
        </decision>
        <consequences>
          No separate distribution repo to keep in sync; the marketplace
          manifest lives beside the plugin it lists.
        </consequences>
      </decision>
    </decisions>

    <risks>
      <risk id="RISK-LATENCY" severity="high">
        <statement>
          Hook overhead on every session start and stop makes the plugin feel
          slow, and developers disable it.
        </statement>
        <mitigation>
          Hooks run the sub-second rqml CLI offline (upstream QGOAL-CHECK-SPEED);
          dormancy in non-RQML projects costs one file-existence test.
        </mitigation>
      </risk>
      <risk id="RISK-FALSE-BLOCK" severity="high">
        <statement>
          Overzealous blocking — failing the stop gate on findings the team
          considers advisory — trains developers to uninstall the plugin.
        </statement>
        <mitigation>
          The gate runs at the project's declared strictness level, surfaces
          the exact diagnostics, and blocks only on what would also fail CI.
        </mitigation>
      </risk>
      <risk id="RISK-CONTRACT-DRIFT" severity="medium">
        <statement>
          The plugin's interpretation of CLI exit codes or JSON drifts from the
          toolchain as versions evolve.
        </statement>
        <mitigation>
          The plugin consumes only the documented, stable contract (exit codes
          0/1/2/64 and the JSON report shapes) and declares a compatible
          toolchain version range.
        </mitigation>
      </risk>
    </risks>
  </catalogs>

  <!-- ============================================================= -->
  <!-- DOMAIN                                                        -->
  <!-- ============================================================= -->
  <domain>
    <overview>
      The domain is the enforcement harness itself: the plugin artifact Claude
      Code loads, the hook events it binds, the verdicts it consumes, and the
      project marker that activates it.
    </overview>
    <entities>
      <entity id="ENT-PLUGIN" name="Plugin">
        <description>
          The installable unit: manifest, hook configuration, slash commands,
          MCP server registration, and optionally a bundled authoring skill.
        </description>
        <attr id="ATTR-PLUGIN-NAME" name="name" type="string" required="true">
          <description>Marketplace-visible plugin name ("rqml").</description>
        </attr>
      </entity>
      <entity id="ENT-HOOK" name="Hook Binding">
        <description>
          A registration of a shell command against a Claude Code hook event
          (SessionStart, PostToolUse, Stop), with a matcher where applicable.
        </description>
        <attr id="ATTR-HOOK-EVENT" name="event" type="enum:SessionStart,PostToolUse,Stop" required="true">
          <description>The host event the binding fires on.</description>
        </attr>
      </entity>
      <entity id="ENT-VERDICT" name="Gate Verdict">
        <description>
          The result of an rqml CLI invocation as consumed by the plugin: the
          process exit code plus the machine-readable JSON report.
        </description>
        <attr id="ATTR-VERDICT-EXIT" name="exitCode" type="enum:0,1,2,64" required="true">
          <description>Documented upstream exit-code contract.</description>
        </attr>
      </entity>
      <entity id="ENT-MARKER" name="Project Marker">
        <description>
          The signal that a project is RQML-governed: an .rqml spec document in
          the project root (conventionally requirements.rqml).
        </description>
      </entity>
    </entities>
    <businessRules>
      <rule id="BR-DORMANT">
        <statement>
          In a project with no .rqml spec document, the plugin MUST do nothing
          beyond the detection test itself.
        </statement>
      </rule>
      <rule id="BR-NO-MODEL">
        <statement>
          No enforcement verdict surfaced by the plugin may originate from a
          language model.
        </statement>
      </rule>
      <rule id="BR-SHOW-YOUR-WORK">
        <statement>
          Whenever the plugin blocks an action, it MUST surface the CLI
          diagnostics that justify the block, verbatim.
        </statement>
      </rule>
      <rule id="BR-EXIT-CONTRACT">
        <statement>
          Exit code 0 means proceed; 1 means validation failure; 2 means
          blocking drift or coverage; 64 means the plugin invoked the CLI
          incorrectly and MUST treat it as its own bug, not the user's.
        </statement>
      </rule>
    </businessRules>
  </domain>

  <!-- ============================================================= -->
  <!-- GOALS                                                         -->
  <!-- ============================================================= -->
  <goals>
    <goal id="GOAL-ENFORCED-LOOP" title="Enforced, not voluntary" priority="must" ownerRef="STK-TEAMS">
      <statement>
        Make the spec-first loop hold for the life of a Claude Code session
        without relying on the model remembering that the process exists.
      </statement>
      <rationale>
        Upstream obstacle OBS-VOLUNTARY: agents drift because compliance is
        voluntary. Hooks remove the reliance on attention and memory.
      </rationale>
    </goal>
    <goal id="GOAL-PARITY" title="Local equals CI" priority="must" ownerRef="STK-MAINTAINER">
      <statement>
        What blocks the agent locally SHALL be exactly what blocks CI: the
        same CLI, the same strictness, the same diagnostics.
      </statement>
      <rationale>
        Divergent local/CI verdicts destroy trust in both; one engine and a
        thin adapter make divergence structurally impossible.
      </rationale>
    </goal>
    <goal id="GOAL-ZERO-CONFIG" title="Zero configuration" priority="should" ownerRef="STK-TEAMS">
      <statement>
        Installing the plugin into an RQML-governed project SHALL require no
        configuration; installing it elsewhere SHALL cost nothing.
      </statement>
    </goal>

    <qgoal id="QGOAL-LATENCY" title="Imperceptible overhead" priority="must">
      <statement>Hook executions SHALL be fast enough not to change how the session feels.</statement>
      <metric>
        Detection in a non-RQML project: a single stat call. Status and check
        hooks: bounded by the upstream interactive-latency target (about one
        second on a typical project).
      </metric>
    </qgoal>
    <qgoal id="QGOAL-SIGNAL" title="High-signal blocking" priority="must">
      <statement>Every block SHALL be actionable; no block without diagnostics.</statement>
      <metric>
        100% of blocking events carry the verbatim CLI diagnostics and the
        command to reproduce them.
      </metric>
    </qgoal>

    <obstacle id="OBS-AGENT-DRIFT" title="Agent forgets the process" likelihood="high" severity="high">
      <statement>
        Long sessions rotate context; the agent stops consulting the spec and
        ships unspecified behavior.
      </statement>
      <mitigation>Session-start anchoring and the stop gate make forgetting recoverable.</mitigation>
    </obstacle>
    <obstacle id="OBS-UNINSTALL" title="Friction-driven uninstall" likelihood="medium" severity="high">
      <statement>
        If the plugin nags, blocks falsely, or slows turns, developers remove
        it and enforcement disappears entirely.
      </statement>
      <mitigation>Fail-open posture, strictness-respecting gate, sub-second hooks.</mitigation>
    </obstacle>

    <goalLink id="GL-DRIFT-THREATENS" from="OBS-AGENT-DRIFT" to="GOAL-ENFORCED-LOOP" type="threatens" confidence="0.9"/>
    <goalLink id="GL-UNINSTALL-THREATENS" from="OBS-UNINSTALL" to="GOAL-ENFORCED-LOOP" type="threatens" confidence="0.8"/>
    <goalLink id="GL-ZERO-REFINES" from="GOAL-ZERO-CONFIG" to="GOAL-ENFORCED-LOOP" type="refines" confidence="0.7"/>
  </goals>

  <!-- ============================================================= -->
  <!-- SCENARIOS                                                     -->
  <!-- ============================================================= -->
  <scenarios>
    <scenario id="SCN-ANCHOR" title="Session starts in an RQML project" actorRef="ACT-AGENT">
      <narrative>
        1. A Claude Code session starts in a project containing requirements.rqml.
        2. The SessionStart hook runs rqml status and injects the summary —
           spec id, coverage gaps, drift state — into the agent's context,
           with a one-line reminder of the loop (show, impact, implement,
           link, check).
        3. The agent begins work already anchored on the spec.
      </narrative>
    </scenario>
    <scenario id="SCN-SPEC-EDIT" title="Agent edits the spec" actorRef="ACT-AGENT">
      <narrative>
        1. The agent writes or edits an .rqml document.
        2. The PostToolUse hook validates the document with the CLI.
        3. Diagnostics are fed straight back to the agent, which fixes the
           document before moving on — invalid spec states never persist
           unnoticed.
      </narrative>
    </scenario>
    <scenario id="SCN-STOP-GATE" title="Agent finishes a task" actorRef="ACT-AGENT">
      <narrative>
        1. The agent considers the task complete and attempts to stop.
        2. The Stop hook runs rqml check at the project's strictness.
        3. Exit 0: the session ends normally. Non-zero: the stop is blocked
           and the diagnostics — unlinked requirements, drifted artifacts,
           invalid spec — are returned, so the agent completes the loop
           (usually rqml link plus a fix) before finishing.
      </narrative>
    </scenario>
    <misuseCase id="MIS-GHOST" title="Unspecified implementation" actorRef="ACT-AGENT">
      <narrative>
        The agent implements behavior with no corresponding requirement. At
        strict and certified levels the stop gate fails on coverage, the
        diagnostics name the gap, and the agent must capture the requirement
        (or the developer must waive it) before the session can end cleanly.
      </narrative>
    </misuseCase>
    <edgeCase id="EDGE-NO-SPEC" title="Plugin installed in a non-RQML project" actorRef="ACT-DEV">
      <narrative>
        No .rqml document exists. Every hook returns immediately after the
        detection test; no context is injected, nothing blocks, and the
        developer notices the plugin only if they run /rqml:init to adopt it.
      </narrative>
    </edgeCase>
    <edgeCase id="EDGE-NO-CLI" title="Toolchain missing" actorRef="ACT-DEV">
      <narrative>
        The project has a spec but the rqml CLI is not installed. The plugin
        warns once per session with the install command, then stays out of the
        way: fail open, never fail closed.
      </narrative>
    </edgeCase>
  </scenarios>

  <!-- ============================================================= -->
  <!-- REQUIREMENTS                                                  -->
  <!-- ============================================================= -->
  <requirements>

    <reqPackage id="PKG-PLUGIN" title="Plugin packaging" ownerRef="STK-MAINTAINER">
      <description>The installable artifact and its distribution.</description>
      <req id="REQ-MANIFEST" type="CR" title="Conformant plugin manifest" status="approved" priority="must">
        <statement>
          The repository SHALL be a valid Claude Code plugin: a
          .claude-plugin/plugin.json manifest naming the plugin "rqml", with
          hooks, commands, skills, and MCP configuration in the locations the
          plugin format documents.
        </statement>
        <acceptance>
          <criterion id="CRIT-MANIFEST-LOADS">
            <given>A Claude Code installation</given>
            <when>The plugin is installed from this repository</when>
            <then>It loads without errors and its commands are listed.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-MARKETPLACE" type="DR" title="Self-hosting marketplace" status="approved" priority="should">
        <statement>
          The repository SHALL carry a .claude-plugin/marketplace.json listing
          the plugin, so installation is a single marketplace-add pointing at
          rqml-org/rqml-claude.
        </statement>
      </req>
      <req id="REQ-THIN-ADAPTER" type="CR" title="No spec logic in the plugin" status="approved" priority="must">
        <statement>
          The plugin SHALL NOT reimplement any validation, coverage, drift,
          impact, or extraction logic; every verdict and every artifact view
          SHALL come from the rqml CLI or the @rqml/mcp server.
        </statement>
        <rationale>
          One engine, many surfaces (upstream GOAL-REUSABLE-ENGINE): a second
          implementation would drift and break local/CI parity.
        </rationale>
        <acceptance>
          <criterion id="CRIT-THIN">
            <given>The plugin source tree</given>
            <when>It is inspected</when>
            <then>No code parses or evaluates RQML documents; hooks and commands only invoke the toolchain and relay its output.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-DORMANT" type="NFR" title="Dormant outside RQML projects" status="approved" priority="must">
        <statement>
          In a project with no .rqml spec document, every hook SHALL return
          immediately after a single existence test, inject nothing, and block
          nothing.
        </statement>
        <acceptance>
          <criterion id="CRIT-DORMANT">
            <given>A session in a project without an .rqml document</given>
            <when>Session start, tool use, and stop events fire</when>
            <then>No context is injected and no action is blocked.</then>
          </criterion>
        </acceptance>
      </req>
    </reqPackage>

    <reqPackage id="PKG-HOOKS" title="Enforcement hooks" ownerRef="STK-TEAMS">
      <description>
        The deterministic loop: anchor at start, validate on spec edits, gate
        on stop.
      </description>
      <req id="REQ-HOOK-ANCHOR" type="FR" title="Session-start anchoring" status="approved" priority="must">
        <statement>
          On session start in an RQML-governed project, the plugin SHALL run
          rqml status and inject its summary into the agent's context, together
          with a compact statement of the five-stage process: Spec, Design
          (ADRs), Plan, Code (show, impact, implement, link), and Verify (finish
          only when check passes).
        </statement>
        <acceptance>
          <criterion id="CRIT-ANCHOR">
            <given>A project with a valid requirements.rqml</given>
            <when>A new session starts</when>
            <then>The agent's context contains the spec docId, coverage summary, and loop reminder before the first user prompt is handled.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-HOOK-SPEC-VALIDATE" type="FR" title="Immediate spec-edit validation" status="approved" priority="must">
        <statement>
          After any Edit or Write that touches an .rqml document, the plugin
          SHALL run rqml validate on the touched document and return the
          diagnostics to the agent as tool feedback.
        </statement>
        <acceptance>
          <criterion id="CRIT-SPEC-EDIT">
            <given>An agent edit that introduces a duplicate id into the spec</given>
            <when>The edit completes</when>
            <then>The duplicate-id diagnostic reaches the agent in the same turn.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-HOOK-STOP-GATE" type="FR" title="Stop gate" status="approved" priority="must">
        <statement>
          When the agent attempts to stop in an RQML-governed project, the
          plugin SHALL run rqml check at the project's strictness level and
          SHALL block the stop when the exit code is non-zero, returning the
          diagnostics as the blocking reason.
        </statement>
        <rationale>
          This is the moment enforcement matters: the gate converts "the agent
          should finish the loop" into "the session cannot end until it has."
        </rationale>
        <notes>
          Loop protection: when a stop attempt has already been blocked once
          and continued by this gate (the host signals this via
          stop_hook_active), a persisting failure SHALL NOT block again; the
          gate surfaces a final warning and lets the session end, so an
          unsatisfiable finding can never trap the agent in an infinite
          block-continue loop.
        </notes>
        <acceptance>
          <criterion id="CRIT-STOP-BLOCKS">
            <given>A project whose linked implementation has drifted</given>
            <when>The agent attempts to stop</when>
            <then>The stop is blocked and the changed-implementation diagnostic is surfaced.</then>
          </criterion>
          <criterion id="CRIT-STOP-PASSES">
            <given>A project where rqml check exits zero</given>
            <when>The agent attempts to stop</when>
            <then>The session ends without interference.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-HOOK-DIAGNOSTICS" type="UXR" title="Verbatim, reproducible diagnostics" status="approved" priority="must">
        <statement>
          Every block and every validation feedback SHALL include the CLI
          diagnostics verbatim and the exact command that reproduces them.
        </statement>
      </req>
      <req id="REQ-HOOK-FAIL-OPEN" type="NFR" title="Fail open" status="approved" priority="must">
        <statement>
          When the rqml CLI is missing or exits with a usage error (64), the
          plugin SHALL NOT block anything; it SHALL warn at most once per
          session, including the toolchain install command.
        </statement>
        <acceptance>
          <criterion id="CRIT-FAIL-OPEN">
            <given>A project with a spec but no rqml CLI on the PATH</given>
            <when>The agent works and stops</when>
            <then>Nothing is blocked and exactly one warning is shown.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-HOOK-PREIMPL" type="FR" title="Pre-implementation approval gate" status="approved" priority="should">
        <statement>
          The plugin SHALL provide a PreToolUse hook that, before an edit to a
          code artifact already linked by an implements edge to a requirement,
          consults the toolchain's approval-gate verdict and denies the edit
          when that requirement is not approved — failing open if the toolchain
          is unavailable, so the agent is never blocked by a missing or hung
          toolchain.
        </statement>
        <rationale>
          The stop gate blocks only at session end, after code is written;
          enforcing approval-before-implementation needs a checkpoint at the
          moment of the edit (ADR-0008). The verdict is the toolchain's
          deterministic result, not the model's (GOAL-ENFORCED-LOOP); fail-open
          matches the plugin's existing hook contract. Net-new, not-yet-linked
          code remains governed by the stop gate.
        </rationale>
        <acceptance>
          <criterion id="CRIT-PREIMPL-DENY">
            <given>An agent edit to code linked by an implements edge to a draft requirement</given>
            <when>The PreToolUse hook runs</when>
            <then>The edit is denied with a message naming the requirement; and when the toolchain is unavailable, the edit proceeds with at most one warning.</then>
          </criterion>
        </acceptance>
      </req>
    </reqPackage>

    <reqPackage id="PKG-COMMANDS" title="Slash commands" ownerRef="STK-TEAMS">
      <description>Explicit entry points for the developer and the agent.</description>
      <req id="REQ-CMD-INIT" type="FR" title="/rqml:init — adopt RQML" status="approved" priority="must">
        <statement>
          The plugin SHALL provide an init command that scaffolds an
          RQML-governed project via rqml init and then guides the agent
          through eliciting and drafting the project's first real
          requirements from the developer.
        </statement>
      </req>
      <req id="REQ-CMD-STATUS" type="FR" title="/rqml:status — re-anchor" status="approved" priority="must">
        <statement>
          The plugin SHALL provide a status command that re-runs the
          session-start anchoring on demand.
        </statement>
      </req>
      <req id="REQ-CMD-CHECK" type="FR" title="/rqml:check — run the gate" status="approved" priority="must">
        <statement>
          The plugin SHALL provide a check command that runs the gate on
          demand and has the agent resolve each finding through the loop
          (show, implement or link, re-check) until it passes.
        </statement>
      </req>
      <req id="REQ-CMD-DESIGN" type="FR" title="/rqml:design — record an ADR" status="approved" priority="should">
        <statement>
          The plugin SHALL provide a design command that runs the Design stage:
          it classifies a decision and, when the decision is ADR-worthy, writes
          an Architecture Decision Record to .rqml/adr/ following the canonical
          format (NNNN-slug.md, immutable once accepted), without implementing
          the decision.
        </statement>
        <acceptance>
          <criterion id="CRIT-CMD-DESIGN">
            <given>A significant design decision discussed via /rqml:design</given>
            <when>The agent concludes it is ADR-worthy</when>
            <then>An ADR file is written to .rqml/adr/ using the canonical naming and template.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CMD-PLAN" type="FR" title="/rqml:plan — draft the plan" status="approved" priority="should">
        <statement>
          The plugin SHALL provide a plan command that runs the Plan stage: it
          assesses readiness and creates or updates a staged implementation plan
          at .rqml/plan.md, framed for coding agents, without implementing it.
        </statement>
        <acceptance>
          <criterion id="CRIT-CMD-PLAN">
            <given>A project with approved requirements</given>
            <when>The developer runs /rqml:plan</when>
            <then>.rqml/plan.md is created or updated with per-stage goals, requirement ids, and verification steps.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CMD-REVIEW" type="FR" title="/rqml:review — accept requirements" status="approved" priority="should">
        <statement>
          The plugin SHALL provide a review command that renders the draft and
          review requirements as an overview and a traceability matrix,
          presents them to the developer for acceptance, and on confirmation
          transitions each accepted requirement to approved via the toolchain's
          approve operation.
        </statement>
        <rationale>
          Adoption already gates on the developer approving requirements by
          hand (REQ-CMD-INIT); a review command makes acceptance an explicit,
          repeatable checkpoint for new requirements mid-project, using the
          toolchain's deterministic surfaces (overview, matrix, approve) rather
          than manual XML edits. The human decides; the toolchain performs the
          edit.
        </rationale>
        <acceptance>
          <criterion id="CRIT-REVIEW-ACCEPT">
            <given>A project with draft requirements</given>
            <when>The developer runs the review command and confirms a requirement</when>
            <then>That requirement's status becomes approved and the others are unchanged.</then>
          </criterion>
        </acceptance>
      </req>
    </reqPackage>

    <reqPackage id="PKG-AGENT-TOOLS" title="Agent tooling" ownerRef="STK-MAINTAINER">
      <description>The read/record loop exposed to the agent as structured tools.</description>
      <req id="REQ-MCP-BUNDLED" type="FR" title="Bundled MCP server" status="approved" priority="must">
        <statement>
          The plugin SHALL register the @rqml/mcp server so the agent has the
          toolchain's tools (validate, status, check, trace, show, impact,
          skeleton, link) in every session, launched via npx with no separate
          installation step.
        </statement>
        <acceptance>
          <criterion id="CRIT-MCP-TOOLS">
            <given>A session with the plugin installed</given>
            <when>The agent lists its tools</when>
            <then>The rqml_* tools are available.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-PATH-DISCIPLINE" type="PR" title="Path inputs over inline XML" status="approved" priority="should">
        <statement>
          Plugin guidance (commands, injected context, skill) SHALL direct the
          agent to call MCP tools with path inputs rather than inlining
          documents, and to record trace links with rqml link or rqml_link
          rather than hand-editing trace XML.
        </statement>
      </req>
      <req id="REQ-SKILL-AUTHORING" type="FR" title="Authoring skill" status="approved" priority="should">
        <statement>
          The plugin SHOULD bundle an authoring skill — activation cues, tag
          semantics, statement quality guidance derived from rqml-skill — so
          drafting good RQML is low-friction while every structural question
          is delegated to the toolchain.
        </statement>
      </req>
    </reqPackage>

    <reqPackage id="PKG-CONFIG" title="Configuration and contracts" ownerRef="STK-MAINTAINER">
      <description>How the plugin stays aligned with the project and the toolchain.</description>
      <req id="REQ-STRICTNESS-RESPECT" type="PR" title="Respect declared strictness" status="approved" priority="must">
        <statement>
          The plugin SHALL run every gate at the strictness level the project
          declares (the AGENTS.md strictness convention), defaulting to
          standard when none is declared.
        </statement>
        <acceptance>
          <criterion id="CRIT-STRICTNESS">
            <given>A project whose AGENTS.md declares strictness strict</given>
            <when>The stop gate runs</when>
            <then>rqml check is invoked with strictness strict.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CLI-CONTRACT" type="IR" title="Consume only the stable contract" status="approved" priority="must">
        <statement>
          The plugin SHALL consume only the documented CLI contract — exit
          codes 0, 1, 2, and 64, and the JSON report shapes of status and
          check — and SHALL declare the toolchain version range it is
          compatible with.
        </statement>
      </req>
      <req id="REQ-NO-RESIDUE" type="NFR" title="Clean uninstall" status="approved" priority="should">
        <statement>
          Uninstalling the plugin SHALL leave the project untouched: no files
          written outside the plugin's own directories except those the
          developer explicitly created via /rqml:init.
        </statement>
      </req>
    </reqPackage>

  </requirements>

  <!-- ============================================================= -->
  <!-- BEHAVIOR                                                      -->
  <!-- ============================================================= -->
  <behavior>
    <stateMachine id="SM-SESSION" name="Enforcement Session" entityRef="ENT-PLUGIN" initial="ST-DORMANT">
      <description>
        The plugin's posture over one Claude Code session.
      </description>
      <state id="ST-DORMANT" name="Dormant" type="initial">
        <description>No .rqml document detected; the plugin does nothing.</description>
        <invariant>Zero injected context, zero blocking, one stat call per event.</invariant>
      </state>
      <state id="ST-ANCHORED" name="Anchored">
        <description>Spec detected and status injected; the loop is active.</description>
      </state>
      <state id="ST-BLOCKED" name="Blocked">
        <description>A stop attempt failed the gate; diagnostics returned to the agent.</description>
        <invariant>The blocking diagnostics are always available to the agent.</invariant>
      </state>
      <state id="ST-CLEAN" name="Clean" type="final">
        <description>The session ended with the gate passing (or dormant).</description>
      </state>
      <transition id="TR-DETECT" from="ST-DORMANT" to="ST-ANCHORED" event="spec-detected">
        <description>Session start finds an .rqml document and anchors the agent.</description>
      </transition>
      <transition id="TR-GATE-FAIL" from="ST-ANCHORED" to="ST-BLOCKED" event="stop-rejected">
        <description>The agent tried to stop; rqml check exited non-zero.</description>
        <guard>Exit code is 1 or 2.</guard>
        <action>Return diagnostics as the blocking reason.</action>
      </transition>
      <transition id="TR-RESOLVE" from="ST-BLOCKED" to="ST-ANCHORED" event="findings-addressed">
        <description>The agent fixes, links, or specifies; work continues.</description>
      </transition>
      <transition id="TR-GATE-PASS" from="ST-ANCHORED" to="ST-CLEAN" event="stop-accepted">
        <description>rqml check exits zero; the session ends.</description>
      </transition>
      <transition id="TR-DORMANT-END" from="ST-DORMANT" to="ST-CLEAN" event="session-end">
        <description>A non-RQML session ends untouched.</description>
      </transition>
    </stateMachine>
  </behavior>

  <!-- ============================================================= -->
  <!-- VERIFICATION                                                  -->
  <!-- ============================================================= -->
  <verification>
    <testSuite id="TS-PLUGIN" title="Plugin behavior suite">
      <description>
        Exercises the hooks, commands, and tool registrations against fixture
        projects (governed, ungoverned, drifted, toolchain-missing).
      </description>
    </testSuite>
    <testCase id="TC-MANIFEST" type="inspection" title="Plugin loads">
      <purpose>Verify manifest conformance.</purpose>
      <steps>Install the plugin from the repository into Claude Code.</steps>
      <expected>It loads without errors; commands, hooks, and MCP tools register.</expected>
    </testCase>
    <testCase id="TC-ANCHOR" type="integration" title="Session-start anchoring">
      <purpose>Verify REQ-HOOK-ANCHOR.</purpose>
      <steps>Start a session in a fixture project with a valid spec.</steps>
      <expected>The injected context contains docId, coverage counts, and the loop reminder.</expected>
    </testCase>
    <testCase id="TC-SPEC-EDIT" type="integration" title="Spec edits validated in-turn">
      <purpose>Verify REQ-HOOK-SPEC-VALIDATE.</purpose>
      <steps>Have the agent introduce a duplicate id, observe the same turn.</steps>
      <expected>The duplicate-id diagnostic is returned as tool feedback.</expected>
    </testCase>
    <testCase id="TC-STOP-BLOCKS" type="acceptance" title="Stop gate blocks on drift">
      <purpose>Verify REQ-HOOK-STOP-GATE (CRIT-STOP-BLOCKS).</purpose>
      <steps>Modify a linked artifact in a fixture project, then have the agent stop.</steps>
      <expected>The stop is blocked; the changed-implementation diagnostic is the reason.</expected>
    </testCase>
    <testCase id="TC-STOP-PASSES" type="acceptance" title="Stop gate passes cleanly">
      <purpose>Verify REQ-HOOK-STOP-GATE (CRIT-STOP-PASSES).</purpose>
      <steps>Have the agent stop in a fixture project where check exits zero.</steps>
      <expected>No interference.</expected>
    </testCase>
    <testCase id="TC-DORMANT" type="integration" title="Dormant in ungoverned projects">
      <purpose>Verify REQ-DORMANT.</purpose>
      <steps>Run a full session in a project without an .rqml document.</steps>
      <expected>No injected context, no blocks, no warnings.</expected>
    </testCase>
    <testCase id="TC-FAIL-OPEN" type="integration" title="Missing toolchain fails open">
      <purpose>Verify REQ-HOOK-FAIL-OPEN.</purpose>
      <steps>Remove the rqml CLI from PATH in a governed fixture; work and stop.</steps>
      <expected>One warning, zero blocks.</expected>
    </testCase>
    <testCase id="TC-PARITY" type="integration" title="Hook verdict equals CI verdict">
      <purpose>Verify GOAL-PARITY via REQ-THIN-ADAPTER.</purpose>
      <steps>Run the stop-gate hook and a bare rqml check on the same fixture.</steps>
      <expected>Identical verdicts and diagnostics.</expected>
    </testCase>
  </verification>

